@{
    ViewData["Title"] = "Home";
}

<h1>OpenDataTables &amp; OpenSelect2 — SampleApp</h1>
<p class="lead">Live demos of the two packages.</p>

<ul>
    <li><a asp-controller="Home" asp-action="Select2">Select2</a> — AJAX paging, cascade, preselect hook, static, read-only, select-all.</li>
    <li><a asp-controller="Home" asp-action="DataTable">DataTable</a> — server-side sort/page, filter card (text/select/static/date), action buttons, custom buttons.</li>
    <li><a asp-controller="Home" asp-action="Editable">Editable DataTable</a> — inline editors with Manual save mode.</li>
</ul>
